DEBUG=True
SECRET_KEY=troque-esta-chave-localmente
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
REQUIRE_AUTH=True
APP_AUTH_TOKEN=troque-este-token-localmente
APP_AUTH_COOKIE_NAME=corecraft_auth
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:8005,http://127.0.0.1:8005

MAINNET_RPC_URL=http://btc-mainnet:8332
MAINNET_RPC_USER=developer
MAINNET_RPC_PASS=troque-esta-senha

SIGNET_RPC_URL=http://btc-signet:38332
SIGNET_RPC_USER=developer
SIGNET_RPC_PASS=troque-esta-senha

REGTEST_RPC_URL=http://btc-regtest:18443
REGTEST_RPC_USER=developer
REGTEST_RPC_PASS=troque-esta-senha

REDIS_URL=redis://redis:6379/0
MAINNET_RPC_ALLOWLIST=getblockchaininfo,getblockcount,getbestblockhash,getblock,getblockhash,getblockheader,getblockstats,getchaintips,getdifficulty,getmempoolinfo,getrawmempool,getnetworkinfo,getpeerinfo,gettxout,gettxoutsetinfo,help,uptime,validateaddress,verifychain
SIGNET_RPC_ALLOWLIST=getblockchaininfo,getblockcount,getbestblockhash,getblock,getblockhash,getblockheader,getblockstats,getchaintips,getdifficulty,getmempoolinfo,getrawmempool,getnetworkinfo,getpeerinfo,gettxout,gettxoutsetinfo,help,uptime,validateaddress,verifychain
REGTEST_RPC_BLOCKLIST=stop

ZMQ_MAINNET_TOPICS=rawblock,hashblock
ZMQ_SIGNET_TOPICS=rawblock,hashblock
ZMQ_REGTEST_TOPICS=rawtx,rawblock,hashblock
CHANNELS_REDIS_LOG_LEVEL=WARNING
