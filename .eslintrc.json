{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "globals": {
        "Terminal": "readonly",
        "FitAddon": "readonly"
    },
    "rules": {
        "no-unused-vars": "off",
        "no-undef": "error"
    }
}